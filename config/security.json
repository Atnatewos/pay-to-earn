{
  "jwt": {
    "expiresIn": "24h",
    "refreshExpiresIn": "7d",
    "description": "JWT token expiration settings"
  },
  "passwords": {
    "minLength": 6,
    "requireNumbers": false,
    "requireUppercase": false,
    "requireSpecialChars": false,
    "maxLoginAttempts": 5,
    "description": "Password policy settings"
  },
  "rateLimits": {
    "general": {
      "windowMs": 900000,
      "max": 100,
      "description": "15 minutes, 100 requests per window"
    },
    "auth": {
      "windowMs": 900000,
      "max": 10,
      "description": "15 minutes, 10 login attempts per window"
    },
    "tasks": {
      "windowMs": 60000,
      "max": 30,
      "description": "1 minute, 30 task requests per window"
    }
  },
  "csp": {
    "enabled": true,
    "allowedScripts": [
      "'self'",
      "'unsafe-inline'",
      "https://telegram.org",
      "https://api.qrserver.com"
    ],
    "allowedStyles": [
      "'self'",
      "'unsafe-inline'",
      "https://fonts.googleapis.com"
    ],
    "allowedFonts": [
      "'self'",
      "https://fonts.gstatic.com"
    ],
    "allowedImages": [
      "'self'",
      "data:",
      "https://api.qrserver.com"
    ],
    "allowedConnections": [
      "'self'",
      "https://pay-to-earn-api.onrender.com",
      "https://api.qrserver.com"
    ]
  },
  "inputSanitization": {
    "stripHtml": true,
    "maxLength": 5000,
    "allowedTags": [],
    "description": "Input sanitization settings"
  },
  "headers": {
    "hsts": {
      "enabled": true,
      "maxAge": 31536000,
      "includeSubDomains": true
    },
    "xFrameOptions": "DENY",
    "xContentTypeOptions": "nosniff",
    "referrerPolicy": "strict-origin-when-cross-origin"
  },
  "cors": {
    "allowedOrigins": [
      "https://pay-to-earn.vercel.app",
      "http://localhost:3000"
    ],
    "description": "CORS allowed origins"
  }
}